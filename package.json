{
  "name": "codex-echoink",
  "version": "1.2.0",
  "description": "Codex EchoInk",
  "main": "dist/main.js",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "check:public": "node scripts/check-public-files.mjs",
    "dev": "node esbuild.config.mjs watch",
    "prepare": "node scripts/install-git-hooks.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "package": "npm run build && node scripts/package.mjs",
    "deploy": "npm run build && node scripts/deploy.mjs"
  },
  "keywords": [
    "obsidian",
    "codex"
  ],
  "author": "AKin-lvyifang",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.3",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.48"
  }
}
