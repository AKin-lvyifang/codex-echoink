{
  "name": "codex-echoink",
  "version": "1.3.0",
  "description": "Codex EchoInk",
  "main": "dist/main.js",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "check:public": "node scripts/check-public-files.mjs",
    "check:release": "node scripts/check-release-contract.mjs",
    "dev": "node esbuild.config.mjs watch",
    "inventory:storage": "node scripts/run-storage-inventory.mjs",
    "lint": "node scripts/check-obsidian-review.mjs",
    "lint:report": "eslint .",
    "lint:update-baseline": "node scripts/check-obsidian-review.mjs --write-baseline",
    "prepare": "node scripts/install-git-hooks.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "verify:obsidian": "npm run check:public && npm run check:release && npm run lint && npm run test && npm run typecheck && npm run build",
    "package": "npm run build && node scripts/package.mjs",
    "deploy": "npm run build && node scripts/deploy.mjs"
  },
  "keywords": [
    "obsidian",
    "codex"
  ],
  "author": "AKin-lvyifang",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@eslint/json": "^0.14.0",
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.3",
    "eslint": "^9.39.5",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "globals": "^17.7.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.48"
  }
}
